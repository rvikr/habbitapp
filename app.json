{
  "expo": {
    "name": "HabbitApp",
    "slug": "habbitapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "habbitapp",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#451ebb"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 30000
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.habbitapp.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "HabbitApp uses notifications to remind you about your habits.",
        "NSUserTrackingUsageDescription": "We use anonymous analytics to understand which features are used so we can make HabbitApp better. No personal data is collected.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.habbitapp.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#451ebb"
      },
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ],
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "name": "HabbitApp",
      "shortName": "HabbitApp",
      "description": "Build habits, track progress, earn badges.",
      "themeColor": "#451ebb",
      "backgroundColor": "#f8f9fa",
      "display": "standalone",
      "startUrl": "/",
      "lang": "en",
      "scope": "/"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#451ebb",
          "defaultChannel": "default"
        }
      ],
      "expo-font",
      "expo-secure-store",
      [
        "expo-updates",
        {
          "username": "REPLACE_WITH_EXPO_USERNAME"
        }
      ],
      "@sentry/react-native",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a2e33959-81eb-4c3c-ba61-c2503eb7beba"
      }
    },
    "owner": "rk12333"
  }
}
